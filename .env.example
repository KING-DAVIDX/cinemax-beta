MONGO_URL=mongodb://user:password@host:port/database?authSource=admin
SPARK_API_KEY=
AUTH_SECRET=

# Optional MongoDB fallback (used automatically if SparkDB is unavailable).
# Same database/collections as SparkDB. Defaults to MONGO_URL if unset.
MONGODB_URI=

# Backwards-compatible legacy name. MONGO_URL is preferred.
SPARK_DATABASE_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

SMTP_USER=cinemax.nexustech@gmail.com
SMTP_PASS=your_gmail_app_password
